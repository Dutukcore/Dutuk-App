{
  "expo": {
    "name": "Dutuk Vendor",
    "slug": "dutukfrontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dutukfrontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vendorapp.dutuk",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Access photos and videos to showcase your work",
        "NSPhotoLibraryAddUsageDescription": "Save media to your photo library",
        "NSCameraUsageDescription": "Take photos and videos of your work",
        "NSMicrophoneUsageDescription": "Record audio for your videos",
        "NSLocationWhenInUseUsageDescription": "We use your location to suggest nearby customers."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FDFDFD"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.vendorapp.dutuk",
      "versionCode": 10,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "CAMERA",
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FDFDFD"
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-web-browser",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "eddf2984-5d28-45ae-a8c7-d80d9a690325"
      }
    }
  }
}